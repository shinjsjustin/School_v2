# Server
PORT=3001
NODE_ENV=development

# Database — TODO: fill in your MySQL credentials
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# Auth — TODO: generate strong random strings (e.g. `openssl rand -hex 32`)
JWT_SECRET=TODO_replace_with_strong_secret
SESSION_SECRET=TODO_replace_with_strong_secret

# API key encryption — 64-char hex = 32 bytes AES-256 key
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=TODO_replace_with_64_char_hex_string

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# URLs
CLIENT_URL=http://localhost:3000
